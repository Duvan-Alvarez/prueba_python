# Railway Environment Variables (Set these in Railway Dashboard)

# Node.js Environment
NODE_ENV=production

# Server Configuration
PORT=8080
# Railway assigns the actual port dynamically, leave blank to use Railway's assignment
# Or set to whatever port the Railway container will expose

# Database
# Railway provides /data volume for persistent storage
DATABASE_PATH=/data/prueba_tecnica.json

# API Keys
# Get from Anthropic: https://console.anthropic.com/
ANTHROPIC_API_KEY=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

# Authentication
ADMIN_USER=admin
ADMIN_PASSWORD=change_this_strong_password

# Frontend URL (Set your Railway deployment URL)
# Example: https://your-app-name.up.railway.app
FRONTEND_URL=https://pruebapython-production-0ecd.up.railway.app

# Test Configuration
TEST_TIME_LIMIT=2700

# Log Level
LOG_LEVEL=info
