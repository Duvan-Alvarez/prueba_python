PORT=5000
NODE_ENV=development
DATABASE_PATH=./data.db

# Anthropic API (required)
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Admin credentials (hardcoded para MVP)
ADMIN_USER=admin
ADMIN_PASSWORD=password123

# Frontend URL (para CORS) - set to your Railway domain in production
FRONTEND_URL=http://localhost:3000

# SMTP email delivery (required to send candidate links by email)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-user@example.com
SMTP_PASS=your-smtp-password
SMTP_FROM="Prueba Tecnica <your-user@example.com>"

# Tiempo límite de la prueba (segundos)
TEST_TIME_LIMIT=2700

# Optional: Log level
LOG_LEVEL=debug
